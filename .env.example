# =============================================================================
# TicketInsight Pro - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Values here are loaded by python-dotenv and override config.yaml defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development, staging, production
APP_ENV=development
# Enable Flask debug mode (auto-reload, detailed errors)
APP_DEBUG=true
# Port and host for the development server
APP_PORT=5000
APP_HOST=0.0.0.0
# Secret key for session signing and CSRF protection (generate a strong random key for production)
SECRET_KEY=change-me-to-a-random-64-char-string

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection URL (format: postgresql+psycopg2://user:pass@host:port/dbname)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ticketinsight
# Connection pool size for SQLAlchemy
DATABASE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Default cache TTL in seconds
REDIS_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log file path (relative to project root or absolute)
LOG_FILE=logs/ticketinsight.log

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# -----------------------------------------------------------------------------
# Metabase Integration (optional)
# -----------------------------------------------------------------------------
# Base URL for your Metabase instance
# METABASE_URL=http://localhost:3001
# API key for Metabase authentication
# METABASE_API_KEY=your-metabase-api-key

# -----------------------------------------------------------------------------
# Ticket Adapter Configuration
# -----------------------------------------------------------------------------
# Adapter type: servicenow, jira, csv
ADAPTER_TYPE=csv

# ServiceNow connection settings (uncomment and fill if using servicenow adapter)
# SNOW_INSTANCE=https://your-instance.service-now.com
# SNOW_USERNAME=your-username
# SNOW_PASSWORD=your-password

# Jira connection settings (uncomment and fill if using jira adapter)
# JIRA_SERVER=https://your-instance.atlassian.net
# JIRA_USERNAME=your-email@example.com
# JIRA_API_TOKEN=your-api-token

# CSV adapter: path to CSV file (relative to project root or absolute)
# CSV_FILE_PATH=data/samples/tickets_sample.csv

# -----------------------------------------------------------------------------
# NLP / Machine Learning Settings
# -----------------------------------------------------------------------------
# spaCy language model to load (run: python -m spacy download en_core_web_sm)
NLP_MODEL=en_core_web_sm
# Batch size for NLP processing pipeline
NLP_BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Pipeline Settings
# -----------------------------------------------------------------------------
# Interval in minutes between automatic pipeline runs (0 = disabled)
PIPELINE_INTERVAL_MINUTES=30

# -----------------------------------------------------------------------------
# Config File Override
# -----------------------------------------------------------------------------
# Path to a custom YAML config file (overrides defaults, overridden by env vars)
# TICKETINSIGHT_CONFIG=config.yaml
